# =============================================================================
# KAVACH Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit the .env file with real tokens to version control.
# =============================================================================

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────

# Your WhatsApp Cloud API permanent access token.
# Get it from: https://developers.facebook.com → Your App → WhatsApp → API Setup
META_ACCESS_TOKEN=your_meta_access_token_here

# Your WhatsApp Business phone number ID (NOT the phone number itself).
# Find it in the Meta App Dashboard under WhatsApp → API Setup → Phone Number ID.
META_PHONE_NUMBER_ID=your_phone_number_id_here

# Webhook verification token — you define this, then enter the same value
# in the Meta App Dashboard when registering your webhook URL.
META_VERIFY_TOKEN=kavach_verify_token_2026
