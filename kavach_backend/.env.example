# =============================================================================
# KAVACH Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit the .env file with real tokens to version control.
# =============================================================================

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────

# Your WhatsApp Cloud API permanent access token.
# Get it from: https://developers.facebook.com → Your App → WhatsApp → API Setup
META_ACCESS_TOKEN=your_meta_access_token_here

# Your WhatsApp Business phone number ID (NOT the phone number itself).
# Find it in the Meta App Dashboard under WhatsApp → API Setup → Phone Number ID.
META_PHONE_NUMBER_ID=your_phone_number_id_here

# Webhook verification token — you define this, then enter the same value
# in the Meta App Dashboard when registering your webhook URL.
META_VERIFY_TOKEN=kavach_verify_token_2026

# ── Takedown Engine — Automated OSINT & Abuse Reporting ──────────────────────

# Google Safe Browsing Lookup API v4 key.
# Get it from: https://console.cloud.google.com/apis/credentials
# Enable "Safe Browsing API" in your GCP project first.
GOOGLE_SAFE_BROWSING_API_KEY=your_safe_browsing_api_key_here

# VirusTotal API v3 key.
# Get your free key from: https://www.virustotal.com/gui/join-us
# Free tier: 4 lookups/min, 500/day — sufficient for KAVACH demo loads.
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# SMTP credentials for dispatching automated abuse emails.
# For Gmail: use an App Password (not your account password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=kavach-soc@example.com
SMTP_PASSWORD=your_app_password_here

# Optional: Override SMTP host/port (defaults to Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

