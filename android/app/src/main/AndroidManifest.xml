<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================================================================== -->
    <!-- YONO SHIELD — PERMISSIONS                                          -->
    <!-- ================================================================== -->

    <!-- PILLAR 1: Clone Radar — Query ALL installed packages on the device
         Required for PackageManager.getInstalledApplications() to return
         a complete list on Android 11+. Without this, only a subset of
         apps are visible due to package visibility restrictions.
         NOTE: Google Play restricts this — fine for hackathon/sideloaded APKs. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- PILLAR 2: SMS Interceptor (placeholder) -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- PILLAR 3: Block Overlay — Draw over other apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Service support — Required for overlay foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Internet — For future URL reputation checks -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="YONO Shield"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- ============================================================== -->
        <!-- MAIN ACTIVITY — Flutter entry point + MethodChannel host       -->
        <!-- ============================================================== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".AppInstallReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- ============================================================== -->
        <!-- OMNI-SCANNER — NotificationListenerService                     -->
        <!-- Intercepts notifications from ALL messaging apps, extracts     -->
        <!-- URLs, and scans them against the KAVACH backend in real-time.   -->
        <!-- Requires user consent via Settings > Notification Access.      -->
        <!-- ============================================================== -->
        <service
            android:name=".OmniScannerService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Flutter embedding metadata -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Package visibility: allow Flutter text processing plugin to query -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        <!-- Required for flutter_tts on Android 11+ (API 30) -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

</manifest>
